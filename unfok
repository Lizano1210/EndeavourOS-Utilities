#!/bin/bash

# ── Colores para output ──────────────────────────────
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# ── Funciones ────────────────────────────────────────
mostrar_uso() {
    echo "Uso: $(basename $0) [opciones]"
    echo ""
    echo "Opciones:"
    echo "  -w    Reiniciar WiFi"
    echo "  -b    Reiniciar Bluetooth"
    echo "  -a    Reiniciar ambos"
    echo "  -h    Mostrar esta ayuda"
}

reiniciar_wifi() {
    echo -e "${YELLOW}>> Reiniciando WiFi...${NC}"

    sudo ip link set wlan0 down
    sleep 1
    sudo ip link set wlan0 up

    sudo systemctl restart NetworkManager
    sleep 2

    if systemctl is-active --quiet NetworkManager; then
        echo -e "${GREEN}✓ WiFi reiniciado correctamente${NC}"
    else
        echo -e "${RED}✗ Error al reiniciar WiFi${NC}"
    fi
}

reiniciar_bluetooth() {
    echo -e "${YELLOW}>> Reiniciando Bluetooth...${NC}"

    # Desbloquear y resetear con rfkill
    sudo rfkill block bluetooth
    sleep 1
    sudo rfkill unblock bluetooth

    # Reiniciar el servicio
    sudo systemctl restart bluetooth
    sleep 2

    if systemctl is-active --quiet bluetooth; then
        echo -e "${GREEN}✓ Bluetooth reiniciado correctamente${NC}"
    else
        echo -e "${RED}✗ Error al reiniciar Bluetooth${NC}"
    fi
}

# ── Manejo de flags ──────────────────────────────────
wifi=false
bluetooth=false

while getopts "wbah" flag; do
    case $flag in
        w) wifi=true ;;
        b) bluetooth=true ;;
        a) wifi=true; bluetooth=true ;;
        h) mostrar_uso; exit 0 ;;
        ?) mostrar_uso; exit 1 ;;
    esac
done

# Si no se pasó ningún flag
if [ "$wifi" = false ] && [ "$bluetooth" = false ]; then
    echo -e "${RED}Error: debes especificar al menos una opción${NC}"
    echo ""
    mostrar_uso
    exit 1
fi

# ── Ejecución ─────────────────────────────────────────
echo "=============================="
echo "   Reinicio de servicios      "
echo "=============================="
echo ""

[ "$wifi" = true ] && reiniciar_wifi
[ "$bluetooth" = true ] && reiniciar_bluetooth

echo ""
echo "=============================="
echo "         Listo                "
echo "=============================="
